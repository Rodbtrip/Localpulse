{
  "extends": "expo/tsconfig.base",
  "compilerOptions": { "strict": true },
  // "exclude" replaces (not merges with) the base config's list, so the base
  // entries are repeated here. supabase/functions is Deno code (Deno global,
  // npm: specifiers) checked by Supabase's own deploy tooling, not tsc.
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js",
    "supabase/functions"
  ]
}
